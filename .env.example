EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Dedicated test project for the RLS/integration suite only — the app itself
# never reads these, it always targets the EXPO_PUBLIC_* project above.
TEST_SUPABASE_URL=https://your-test-project-ref.supabase.co
TEST_SUPABASE_ANON_KEY=your-test-project-anon-key-here

# Test project's service_role key — seed-script-only, NEVER the app's own
# credential. Bypasses RLS entirely. Get it from the TEST project's Supabase
# dashboard (Settings -> API), never production. Used only by scripts/seed.js,
# run by hand (`npm run seed`) — never wired into CI, never imported in src/.
TEST_SUPABASE_SERVICE_ROLE_KEY=your-test-project-service-role-key-here
