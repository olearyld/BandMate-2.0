# Loaded only by `npm run start:test` (via dotenv-cli), never by the default
# `npm start`. Points the running app at the dedicated TEST Supabase project
# instead of production — same URL/anon key as TEST_SUPABASE_URL/ANON_KEY in
# .env, just under the EXPO_PUBLIC_ names the app actually reads.
EXPO_PUBLIC_SUPABASE_URL=https://your-test-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-test-project-anon-key-here

# Drives the red "TEST PROJECT" banner in App.tsx — leave this set to `test`.
EXPO_PUBLIC_APP_ENV=test
