{
  "name": "bandmate",
  "version": "1.0.0",
  "main": "index.ts",
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.18.8",
    "@react-navigation/native": "^7.3.8",
    "@react-navigation/native-stack": "^7.17.10",
    "@supabase/supabase-js": "^2.109.0",
    "babel-preset-expo": "~57.0.0",
    "expo": "~57.0.6",
    "expo-asset": "~57.0.5",
    "expo-audio": "~57.0.2",
    "expo-file-system": "~57.0.1",
    "expo-image-manipulator": "~57.0.4",
    "expo-image-picker": "~57.0.4",
    "expo-notifications": "~57.0.6",
    "expo-video": "~57.0.1",
    "expo-video-thumbnails": "~57.0.1",
    "nativewind": "^4.2.6",
    "react": "19.2.3",
    "react-native": "0.86.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.29.7",
    "@faker-js/faker": "^10.5.0",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.2.2",
    "@types/ws": "^8.18.1",
    "dotenv": "^17.4.2",
    "dotenv-cli": "^11.0.0",
    "jest": "~29.7.0",
    "jest-expo": "~57.0.2",
    "react-test-renderer": "^19.2.3",
    "tailwindcss": "^3.4.19",
    "typescript": "~6.0.3",
    "ws": "^8.21.1"
  },
  "scripts": {
    "start": "expo start",
    "start:test": "EXPO_NO_DOTENV=1 dotenv -e .env.test -- expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "jest --selectProjects unit",
    "test:integration": "jest --selectProjects integration",
    "test:all": "jest",
    "seed": "node scripts/seed.js",
    "seed:reset": "node scripts/seed.js --reset-only"
  },
  "private": true,
  "jest": {
    "projects": [
      {
        "displayName": "unit",
        "preset": "jest-expo",
        "testMatch": [
          "<rootDir>/__tests__/unit/**/*.test.[jt]s?(x)"
        ]
      },
      {
        "displayName": "integration",
        "testEnvironment": "node",
        "testMatch": [
          "<rootDir>/__tests__/integration/**/*.test.[jt]s?(x)"
        ],
        "setupFiles": [
          "<rootDir>/jest.setup.js"
        ],
        "transform": {
          "^.+\\.[jt]sx?$": [
            "babel-jest",
            {
              "configFile": "./babel.integration.config.js"
            }
          ]
        }
      }
    ]
  }
}
